# Copy to .env and fill in values. .env is gitignored.

MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
MODEL_REVISION=main
MAX_NEW_TOKENS=1024
TEMPERATURE=0.0

VLLM_HOST=localhost
VLLM_PORT=8000
VLLM_API_KEY=extractor-local

API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=info

OUTPUT_DIR=checkpoints/
DATA_DIR=data/
SEED=42

# Required for dataset generation (sessions 4-5)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Required for experiment tracking (session 11)
WANDB_API_KEY=
WANDB_PROJECT=extractor

# Required for private model access (sessions 2+)
HF_TOKEN=
